generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  email        String   @db.VarChar(255)
  phone        String   @db.VarChar(50)
  message      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  activityType String   @map("activity_type") @db.VarChar(100)
  capacity     String   @db.VarChar(100)
  cycleInfo    String?  @map("cycle_info") @db.VarChar(100)
  name         String   @db.VarChar(255)
  problemType  String   @map("problem_type") @db.Text
  region       String   @db.VarChar(255)
  status       String   @default("NEW") @db.VarChar(50)

  @@map("leads")
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique @db.VarChar(255)
  name           String   @db.VarChar(255)
  isDisinfectant Boolean  @default(false) @map("is_disinfectant")
  category       Zone
  step           Int      @default(1)
  description    String   @db.LongText
  dosage         String?  @db.VarChar(255)
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("products")
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(255)
  coverImage  String?  @map("cover_image") @db.VarChar(500)
  tags        String   @db.Text
  titleFr     String   @map("title_fr") @db.VarChar(500)
  titleEn     String   @map("title_en") @db.VarChar(500)
  titleAr     String   @map("title_ar") @db.VarChar(500)
  contentFr   String   @map("content_fr") @db.LongText
  contentEn   String   @map("content_en") @db.LongText
  contentAr   String   @map("content_ar") @db.LongText
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("blog_posts")
}

model User {
  id            String    @id @default(cuid())
  name          String?   @db.VarChar(255)
  email         String?   @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  password      String?   @db.VarChar(255)
  image         String?   @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_user_id_fkey")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_fkey")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Zone {
  BATIMENT
  EAU
  AMBIANCE
}
