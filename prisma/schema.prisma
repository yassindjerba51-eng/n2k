generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  email        String   @db.VarChar(255)
  phone        String   @db.VarChar(50)
  message      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  activityType String   @map("activity_type") @db.VarChar(100)
  capacity     String   @db.VarChar(100)
  cycleInfo    String?  @map("cycle_info") @db.VarChar(100)
  name         String   @db.VarChar(255)
  problemType  String   @map("problem_type") @db.Text
  region       String   @db.VarChar(255)
  status       String   @default("NEW") @db.VarChar(50)

  @@map("leads")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  status    String   @default("NEW") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique @db.VarChar(255)
  name           String   @db.VarChar(255)
  isDisinfectant Boolean  @default(false) @map("is_disinfectant")
  category       Zone
  step           Int      @default(1)
  description    Json
  dosage         String?  @db.VarChar(255)
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("products")
}

model BlogCategory {
  id          Int        @id @default(autoincrement())
  slugFr      String     @unique @map("slug_fr") @db.VarChar(255)
  slugEn      String     @unique @map("slug_en") @db.VarChar(255)
  slugAr      String     @unique @map("slug_ar") @db.VarChar(255)
  nameFr      String     @map("name_fr") @db.VarChar(255)
  nameEn      String     @map("name_en") @db.VarChar(255)
  nameAr      String     @map("name_ar") @db.VarChar(255)
  titleFr     String     @map("title_fr") @db.VarChar(500)
  titleEn     String     @map("title_en") @db.VarChar(500)
  titleAr     String     @map("title_ar") @db.VarChar(500)
  subtitleFr  String?    @map("subtitle_fr") @db.VarChar(500)
  subtitleEn  String?    @map("subtitle_en") @db.VarChar(500)
  subtitleAr  String?    @map("subtitle_ar") @db.VarChar(500)
  headerImage String?    @map("header_image") @db.VarChar(500)
  createdAt   DateTime   @default(now()) @map("created_at")
  posts       BlogPost[] @relation("BlogPostCategories")

  @@map("blog_categories")
}

model BlogPost {
  id           Int            @id @default(autoincrement())
  slug         String         @unique @db.VarChar(255)
  slugFr       String         @unique @default("") @map("slug_fr") @db.VarChar(255)
  slugEn       String         @unique @default("") @map("slug_en") @db.VarChar(255)
  slugAr       String         @unique @default("") @map("slug_ar") @db.VarChar(255)
  coverImage   String?        @map("cover_image") @db.VarChar(500)
  featured     Boolean        @default(false)
  titleFr      String         @map("title_fr") @db.VarChar(500)
  titleEn      String         @map("title_en") @db.VarChar(500)
  titleAr      String         @map("title_ar") @db.VarChar(500)
  metaTitleFr  String?        @map("meta_title_fr") @db.VarChar(500)
  metaTitleEn  String?        @map("meta_title_en") @db.VarChar(500)
  metaTitleAr  String?        @map("meta_title_ar") @db.VarChar(500)
  metaDescFr   String?        @map("meta_desc_fr") @db.VarChar(1000)
  metaDescEn   String?        @map("meta_desc_en") @db.VarChar(1000)
  metaDescAr   String?        @map("meta_desc_ar") @db.VarChar(1000)
  contentFr    String         @map("content_fr") @db.LongText
  contentEn    String         @map("content_en") @db.LongText
  contentAr    String         @map("content_ar") @db.LongText
  publishedAt  DateTime       @default(now()) @map("published_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  categories   BlogCategory[] @relation("BlogPostCategories")
  tags         Json           @default("[]") @map("tags")

  @@map("blog_posts")
}

model User {
  id            String    @id @default(cuid())
  name          String?   @db.VarChar(255)
  email         String?   @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  password      String?   @db.VarChar(255)
  image         String?   @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_user_id_fkey")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_fkey")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Zone {
  BATIMENT
  EAU
  AMBIANCE
}

model SiteSettings {
  id              String   @id @default("global")
  siteName        String   @map("site_name") @db.VarChar(255)
  logoUrl         String?  @map("logo_url") @db.VarChar(500)
  
  contactEmail    String?  @map("contact_email") @db.VarChar(255)
  contactPhone    String?  @map("contact_phone") @db.VarChar(50)
  contactFax      String?  @map("contact_fax") @db.VarChar(50)
  physicalAddress String?  @map("physical_address") @db.Text
  mainWebsiteUrl  String?  @map("main_website_url") @db.VarChar(255)

  facebookUrl     String?  @map("facebook_url") @db.VarChar(255)
  instagramUrl    String?  @map("instagram_url") @db.VarChar(255)
  linkedinUrl     String?  @map("linkedin_url") @db.VarChar(255)
  twitterUrl      String?  @map("twitter_url") @db.VarChar(255)

  smtpFromEmail   String?  @map("smtp_from_email") @db.VarChar(255)
  smtpFromName    String?  @map("smtp_from_name") @db.VarChar(255)
  smtpHost        String?  @map("smtp_host") @db.VarChar(255)
  smtpPort        Int?     @map("smtp_port")
  smtpUser        String?  @map("smtp_user") @db.VarChar(255)
  smtpPassword    String?  @map("smtp_password") @db.VarChar(255)

  geminiApiKey       String?  @map("gemini_api_key") @db.VarChar(500)
  geminiContentModel String?  @map("gemini_content_model") @db.VarChar(255)
  geminiImageModel   String?  @map("gemini_image_model") @db.VarChar(255)

  pollinationsApiKey String?  @map("pollinations_api_key") @db.VarChar(500)
  pollinationsModel  String?  @map("pollinations_model") @db.VarChar(255)

  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
